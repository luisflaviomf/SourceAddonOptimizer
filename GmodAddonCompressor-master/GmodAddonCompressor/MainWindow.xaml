                                             IsEnabled="{Binding OptimizerUsePlanar}" />
                                </StackPanel>
                            </Grid>
                                    <TextBlock Style="{StaticResource MutedText}"
                                               Margin="0,8,0,0"
                                               Text="Disabled keeps the baseline model pipeline unchanged. Enabled adds the optional planar-collapse pass." />
