                                           x:Name="TextBlock_AddonMergeCurrent"
                                           Style="{StaticResource ValueText}"
                                           Text="Idle" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="Status" />
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Margin="16,10,0,0"
                                           x:Name="TextBlock_AddonMergeStatus"
                                           Style="{StaticResource ValueText}"
                                           Text="Idle" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Diagnostics" />
                                <TextBox x:Name="TextBox_AddonMergeDiagnostics"
                                         Style="{StaticResource ReportTextBox}"
                                         Margin="0,10,0,0"
                                         MinHeight="150" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Log" />
                                <TextBox x:Name="TextBox_AddonMergeLog"
