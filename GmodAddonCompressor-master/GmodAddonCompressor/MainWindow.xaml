                                                Click="Button_AddonMergeOpenMerged_Click"
                                                Content="Open Merged"
                                                Width="110"
                                                Margin="0,0,8,8"
                                                IsEnabled="False" />
                                        <Button x:Name="Button_AddonMergeOpenWork"
                                                Click="Button_AddonMergeOpenWork_Click"
                                                Content="Open Work"
                                                Width="100"
                                                Margin="0,0,8,8"
                                                IsEnabled="False" />
                                        <Button x:Name="Button_AddonMergeOpenReports"
                                                Click="Button_AddonMergeOpenReports_Click"
                                                Content="Open Reports"
                                                Width="110"
                                                Margin="0,0,0,8"
                                                IsEnabled="False" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource LabelText}" Text="Progress" />
                                    <TextBlock Grid.Column="1"
                                               x:Name="TextBlock_AddonMergeProgressPercent"
                                               Style="{StaticResource ValueText}"
                                               Text="0%" />
                                </Grid>
                                <TextBlock x:Name="TextBlock_AddonMergeProgressDetail"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0"
                                           Text="Idle" />
                                <ProgressBar x:Name="ProgressBar_AddonMerge"
                                             Margin="0,10,0,0"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0" />
