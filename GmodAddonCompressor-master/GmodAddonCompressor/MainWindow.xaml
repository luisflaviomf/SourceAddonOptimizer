                </Border>
                </Grid>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Optimize Maps">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Grid Background="{DynamicResource AppBackground}" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.25*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="MAP INPUT" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Addon and Staging" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Use an extracted addon with maps/*.bsp or point to a root that still contains .gma/.bin archives for automatic staging." />

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Addon root" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TextBox_MapScanRootPath"
                                             TextChanged="TextBox_MapScanRootPath_TextChanged"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap" />
                                    <Button x:Name="Button_SelectMapScanRoot"
                                            Click="Button_SelectMapScanRoot_Click"
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ButtonAccent}"
                                            Content="Select Root"
                                            Width="110" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="gmad.exe" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TextBox_MapGmadPath"
                                             Text="{Binding ElementName=TextBox_UnpackGmadPath, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap" />
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Click="Button_AutoDetectGmad_Click"
                                            Content="Auto-detect"
                                            Width="100" />
                                    <Button Grid.Column="2"
                                            Margin="8,0,0,0"
                                            Click="Button_BrowseGmad_Click"
                                            Content="Browse"
                                            Width="80" />
                                </Grid>
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0"
                                           Text="Used only when the selected root still contains raw .gma/.bin archives and no maps/*.bsp yet." />
                            </StackPanel>
                        </Border>

                        <Expander Margin="0,12,0,0" Header="Map Asset Compression Settings">
                            <Border Style="{StaticResource CardInnerPanel}" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource HintText}"
                                               Text="These staged-asset settings mirror the Compress tab and affect the files optimized inside the map work folder." />

                                    <TextBlock Style="{StaticResource LabelText}" Margin="0,14,0,0" Text="Asset types" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <CheckBox Margin="0,0,12,8" Content="VTF" IsChecked="{Binding CompressVTF}" />
                                        <CheckBox Margin="0,0,12,8" Content="WAV" IsChecked="{Binding CompressWAV}" />
                                        <CheckBox Margin="0,0,12,8" Content="MP3" IsChecked="{Binding CompressMP3}" />
                                        <CheckBox Margin="0,0,12,8" Content="OGG" IsChecked="{Binding CompressOGG}" />
                                        <CheckBox Margin="0,0,12,8" Content="JPG" IsChecked="{Binding CompressJPG}" />
                                        <CheckBox Margin="0,0,12,8" Content="PNG" IsChecked="{Binding CompressPNG}" />
                                        <CheckBox Margin="0,0,0,8" Content="LUA" IsChecked="{Binding CompressLUA}" />
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource LabelText}" Margin="0,12,0,0" Text="Image settings" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="Reducing resolution" />
                                        <ComboBox Grid.Row="0" Grid.Column="1"
                                                  ItemsSource="{Binding ImageReducingResolutionList}"
                                                  SelectedIndex="{Binding ImageReducingResolutionListIndex, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="Width limit" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"
                                                  ItemsSource="{Binding ImageSizeLimitList}"
                                                  SelectedIndex="{Binding ImageWidthLimitIndex, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="Height limit" />
                                        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0"
                                                  ItemsSource="{Binding ImageSizeLimitList}"
                                                  SelectedIndex="{Binding ImageHeightLimitIndex, Mode=TwoWay}" />
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource LabelText}" Text="Skip width" />
                                        <TextBox Grid.Column="1" Text="{Binding ImageSkipWidth}" />
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource LabelText}" Text="Skip height" />
                                        <TextBox Grid.Column="1" Text="{Binding ImageSkipHeight}" />
                                    </Grid>

                                    <CheckBox Margin="0,10,0,0" Content="Reduce exactly to Width/Height limits" IsChecked="{Binding ReduceExactlyToLimits}" />
                                    <CheckBox Margin="0,8,0,0" Content="Maintain image aspect ratio" IsChecked="{Binding KeepImageAspectRatio}" />
                                    <CheckBox Margin="0,8,0,0" Content="ImageMagick VTF compress (Demo)" IsChecked="{Binding ImageMagickVTFCompress}" />

                                    <TextBlock Style="{StaticResource LabelText}" Margin="0,14,0,0" Text="Audio and script settings" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="WAV sample rate" />
                                        <ComboBox Grid.Row="0" Grid.Column="1"
                                                  ItemsSource="{Binding WavRateList}"
                                                  SelectedIndex="{Binding WavRateListIndex, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="MP3 bitrate" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"
                                                  ItemsSource="{Binding AudioBitrateList}"
                                                  SelectedIndex="{Binding Mp3BitrateIndex, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="OGG quality" />
                                        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0"
                                                  ItemsSource="{Binding OggQualityList}"
                                                  SelectedIndex="{Binding OggQualityIndex, Mode=TwoWay}" />
                                    </Grid>
                                    <CheckBox Margin="0,10,0,0" Content="Protect WAV loop behavior when possible" IsChecked="{Binding AudioLoopSafe}" />
                                    <CheckBox Margin="0,8,0,0" Content="Minimalize staged LUA when enabled" IsChecked="{Binding ChangeOriginalCodeToMinimalistic}" />

                                    <TextBlock Style="{StaticResource MutedText}"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap"
                                               Text="Embedded model files are still inventoried only. This pipeline does not run the Models optimizer on staged pak content yet." />
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="SCOPE" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Current Scope" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="This tab stays conservative: scan maps, stage pak content, optimize staged assets, then rebuild and reinject only when it is safe." />

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Conservative v1 target" />
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Text="Only optimize content embedded in the BSP pak, prioritizing VTF. No geometry, lightmaps, visibility, or structural lump changes." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Rebuild guardrails" />
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Text="Reinjection runs only when the BSP stays readable as VBSP, the PAKFILE remains a valid ZIP, offsets stay in range, and the layout is safe to rewrite." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="SUMMARY" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Current Step Summary" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Review the current scan or build summary and inspect the main staging metrics before running the next step." />

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Summary" />
                                <TextBox x:Name="TextBox_MapScanSummary"
                                         Style="{StaticResource ReportTextBox}"
                                         Margin="0,10,0,0"
                                         MinHeight="160" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Inventory metrics" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="BSP found" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TextBlock_MapScanBspCount" Style="{StaticResource ValueText}" Text="0" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="16,0,0,0" Style="{StaticResource LabelText}" Text="Valid pak ZIP" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" x:Name="TextBlock_MapScanPakZipCount" Style="{StaticResource ValueText}" Text="0" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="Staged BSP" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" x:Name="TextBlock_MapScanStagedBspCount" Style="{StaticResource ValueText}" Text="0" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Margin="16,10,0,0" Style="{StaticResource LabelText}" Text="Staged files" />
                                    <TextBlock Grid.Row="1" Grid.Column="3" Margin="0,10,0,0" x:Name="TextBlock_MapScanStagedFileCount" Style="{StaticResource ValueText}" Text="0" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="Future candidate" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" x:Name="TextBlock_MapScanCandidateCount" Style="{StaticResource ValueText}" Text="0" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Margin="16,10,0,0" Style="{StaticResource LabelText}" Text="Blocked" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Margin="0,10,0,0" x:Name="TextBlock_MapScanBlockedCount" Style="{StaticResource ValueText}" Text="0" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="Addon total" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" x:Name="TextBlock_MapScanAddonSize" Style="{StaticResource ValueText}" Text="0 B" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Margin="16,10,0,0" Style="{StaticResource LabelText}" Text="PAK total" />
                                    <TextBlock Grid.Row="3" Grid.Column="3" Margin="0,10,0,0" x:Name="TextBlock_MapScanPakTotalSize" Style="{StaticResource ValueText}" Text="0 B" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Style="{StaticResource CardEyebrowText}" Text="EXECUTION" />
                            <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Run" />
                            <TextBlock Style="{StaticResource HintText}"
                                       Margin="0,0,0,12"
                                       Text="Scan and stage first, optimize staged assets next, then rebuild and reinject only when the current work session is ready." />

                            <Border Style="{StaticResource ActionBarCard}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Actions" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button x:Name="Button_MapScanRun"
                                                Style="{StaticResource ButtonAccent}"
                                                Click="Button_MapScanRun_Click"
                                                Content="Scan + Stage"
                                                Width="118"
                                                Margin="0,0,8,8" />
                                        <Button x:Name="Button_MapStageOptimize"
                                                Style="{StaticResource ButtonAccent}"
                                                Click="Button_MapStageOptimize_Click"
                                                Content="Optimize Staging"
                                                Width="130"
                                                Margin="0,0,8,8"
                                                IsEnabled="False" />
                                        <Button x:Name="Button_MapBuildRun"
                                                Style="{StaticResource ButtonAccent}"
                                                Click="Button_MapBuildRun_Click"
                                                Content="Build + Inject"
                                                Width="120"
                                                Margin="0,0,8,8"
                                                IsEnabled="False" />
                                        <Button x:Name="Button_MapScanCancel"
                                                Style="{StaticResource ButtonDanger}"
                                                Click="Button_MapScanCancel_Click"
                                                Content="Cancel"
                                                Width="100"
                                                Margin="0,0,0,8"
                                                IsEnabled="False" />
                                    </WrapPanel>
                                    <WrapPanel Margin="0,2,0,0">
                                        <Button x:Name="Button_MapScanOpenRoot"
                                                Click="Button_MapScanOpenRoot_Click"
                                                Content="Open Root"
                                                Width="100"
                                                Margin="0,0,8,0"
                                                IsEnabled="False" />
                                        <Button x:Name="Button_MapScanOpenWork"
                                                Click="Button_MapScanOpenWork_Click"
                                                Content="Open Work"
                                                Width="100"
                                                Margin="0,0,8,0"
                                                IsEnabled="False" />
                                        <Button x:Name="Button_MapBuildOpenOutput"
                                                Click="Button_MapBuildOpenOutput_Click"
                                                Content="Open Output"
                                                Width="118"
                                                IsEnabled="False" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Progress" />
                                <ProgressBar x:Name="ProgressBar_MapScan"
                                             Margin="0,10,0,0"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="Phase" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Margin="16,0,0,0"
                                           x:Name="TextBlock_MapScanPhase"
                                           Style="{StaticResource StatusTextBlockStyle}"
                                           Text="Idle" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Margin="0,10,0,0"
                                           Style="{StaticResource LabelText}"
                                           Text="Current item" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Margin="16,10,0,0"
                                           x:Name="TextBlock_MapScanCurrent"
                                           Style="{StaticResource ValueText}"
                                           Text="Idle" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Margin="0,10,0,0"
                                           Style="{StaticResource LabelText}"
                                           Text="Status" />
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Margin="16,10,0,0"
                                           x:Name="TextBlock_MapScanStatus"
                                           Style="{StaticResource ValueText}"
                                           Text="Idle" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Log" />
                                <TextBox x:Name="TextBox_MapScanLog"
                                         Style="{StaticResource LogTextBox}"
                                         Margin="0,10,0,0"
                                         MinHeight="240" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                </Grid>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Pipeline">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Grid Background="{DynamicResource AppBackground}" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="PIPELINE INPUT" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Addon" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Pick the addon root used for the chained Models then Compress workflow." />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource LabelText}" Text="Source addon" />
                            <Button Style="{StaticResource HelpIconButton}"
                                    Content="?"
                                    Margin="8,0,0,0"
                                    ToolTipService.Placement="Mouse"
                                    ToolTipService.InitialShowDelay="250"
                                    ToolTipService.ShowDuration="35000">
                                <Button.ToolTip>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Addon usado no Pipeline (Models → Compress)." />
                                        <LineBreak />
                                        <Run Text="Efeito: a compressão roda no output otimizado (quando Models termina com sucesso)." />
                                    </TextBlock>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="Button_SelectDirectoryPipeline"
                                    Style="{StaticResource ButtonAccent}"
                                    Content="Select Addon"
                                    Width="118"
                                    IsEnabled="{Binding UnlockedUI}" />
                            <TextBox Grid.Column="1"
                                     Margin="12,0,0,0"
                                     IsReadOnly="True"
                                     Text="{Binding AddonDirectoryPath}"
                                     TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>

                        <Border Style="{StaticResource CardInnerPanel}"
                                Margin="0,12,0,0"
                                Visibility="{Binding AddonWorkshopWarningVisibility}"
                                BorderBrush="{DynamicResource Danger}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}"
                                           Foreground="{DynamicResource Danger}"
                                           Text="Workshop warning" />
                                <TextBox Margin="0,10,0,0"
                                         Text="{Binding AddonWorkshopWarningText}"
                                         Style="{StaticResource ReportTextBox}"
                                         Foreground="{DynamicResource Danger}"
                                         BorderBrush="{DynamicResource Danger}"
                                         MinHeight="96" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="PIPELINE FLOW" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Pipeline Steps" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Run the fixed Models then Compress sequence. This tab orchestrates the flow without changing either step's logic." />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource LabelText}" Text="Execution order" />
                            <Button Style="{StaticResource HelpIconButton}"
                                    Content="?"
                                    Margin="8,0,0,0"
                                    ToolTipService.Placement="Mouse"
                                    ToolTipService.InitialShowDelay="250"
                                    ToolTipService.ShowDuration="45000">
                                <Button.ToolTip>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Executa as etapas em sequência (uma de cada vez):" />
                                        <LineBreak />
                                        <Run Text="1) Models: otimiza/recompila modelos e gera output." />
                                        <LineBreak />
                                        <Run Text="2) Compress: comprime recursos no output gerado." />
                                        <LineBreak />
                                        <Run Text="Cancel: interrompe a etapa atual com segurança (sem travar a UI)." />
                                    </TextBlock>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>
                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                            <StackPanel>
                                <CheckBox Content="Run Models" IsChecked="True" IsEnabled="False" />
                                <CheckBox Margin="0,8,0,0" Content="Run Compress" IsChecked="True" IsEnabled="False" />
                                <TextBlock Style="{StaticResource MutedText}" Margin="0,8,0,0" Text="Compress runs on the optimized output from the Models step." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ActionBarCard}" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="Button_StartPipeline"
                                        Style="{StaticResource ButtonAccent}"
                                        Content="Run Pipeline"
                                        Width="140"
                                        IsEnabled="{Binding PipelineCanStart}" />
                                <Button x:Name="Button_CancelPipeline"
                                        Style="{StaticResource ButtonDanger}"
                                        Margin="8,0,0,0"
                                        Content="Cancel"
                                        Width="90"
                                        IsEnabled="False" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="EXECUTION" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Progress and Report" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Track the current phase, inspect the final summary, and open the generated folders from one consistent execution panel." />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource LabelText}" Text="Session status" />
                            <Button Style="{StaticResource HelpIconButton}"
                                    Content="?"
                                    Margin="8,0,0,0"
                                    ToolTipService.Placement="Mouse"
                                    ToolTipService.InitialShowDelay="250"
                                    ToolTipService.ShowDuration="45000">
                                <Button.ToolTip>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Mostra o progresso da etapa atual (Phase + Current item) e um resumo final." />
                                        <LineBreak />
                                        <Run Text="Open Output/Work/Logs ficam disponíveis quando houver caminhos detectados." />
                                        <LineBreak />
                                        <Run Text="Copy Summary copia um resumo (paths + exit codes + última linha de erro) para facilitar report de bugs." />
                                    </TextBlock>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Progress" />
                                <ProgressBar x:Name="ProgressBar_Pipeline"
                                             Margin="0,10,0,0"
                                             Minimum="{Binding PipelineProgressMinValue}"
                                             Maximum="{Binding PipelineProgressMaxValue}"
                                             Value="{Binding PipelineProgressValue}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="Phase" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Margin="16,0,0,0"
                                           Style="{StaticResource StatusTextBlockStyle}"
                                           Text="{Binding PipelineStatusText}" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Margin="0,10,0,0"
                                           Style="{StaticResource LabelText}"
                                           Text="Current item" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Margin="16,10,0,0"
                                           Style="{StaticResource ValueText}"
                                           Text="{Binding PipelineProgressText}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Summary" />
                                <TextBox Text="{Binding PipelineSummaryText}"
                                         Style="{StaticResource ReportTextBox}"
                                         Margin="0,10,0,0"
                                         MinHeight="92" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Size report" />
                                <TextBox Text="{Binding PipelineSizeReportText}"
                                         Style="{StaticResource ReportTextBox}"
                                         Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ActionBarCard}" Margin="0,12,0,0">
                            <UniformGrid Columns="2">
                                <Button x:Name="Button_OpenPipelineOutput"
                                        Content="Open Output"
                                        IsEnabled="False"
                                        Margin="0,0,8,8" />
                                <Button x:Name="Button_OpenPipelineWork"
                                        Content="Open Work"
                                        IsEnabled="False"
                                        Margin="0,0,0,8" />
                                <Button x:Name="Button_OpenPipelineLogs"
                                        Content="Open Logs"
                                        IsEnabled="False"
                                        Margin="0,0,8,0" />
                                <Button x:Name="Button_CopyPipelineSummary"
                                        Content="Copy Summary"
                                        IsEnabled="False" />
                            </UniformGrid>
                        </Border>
                    </StackPanel>
                </Border>
                </Grid>
            </ScrollViewer>
        </TabItem>
    </TabControl>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,24,24,0"
                    Panel.ZIndex="1"
                    IsHitTestVisible="False">
            <TextBlock x:Name="VersionId"
                       Style="{StaticResource MutedText}"
                       Text="VERSION" />
            <TextBlock Style="{StaticResource MutedText}"
                       Margin="12,0,0,0"
                       Text="Author: Hanic" />
        </StackPanel>
    </Grid>
</Window>
