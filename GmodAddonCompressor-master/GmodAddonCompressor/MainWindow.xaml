                                                    <DataTrigger Binding="{Binding ModelsStatusText}" Value="">
                                                        <Setter Property="Text" Value="Ready" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ModelsStatusText}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="Ready" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Margin="0,8,0,0"
                                               Style="{StaticResource LabelText}"
                                               Text="Current item" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Margin="14,8,0,0"
                                               Style="{StaticResource ValueText}"
                                               Text="{Binding ModelsProgressText}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <Border Margin="0,10,0,0">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource CardInnerPanel}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ModelsSizeReportText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ModelsSizeReportText}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Size report" />
                                    <TextBox Text="{Binding ModelsSizeReportText}"
                                             Style="{StaticResource ReportTextBox}"
                                             Margin="0,8,0,0"
                                             MinHeight="96" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Descompactar addons">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Grid Background="{DynamicResource AppBackground}" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.25*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="SCAN INPUT" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Root Folder" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Scan the selected root for .gma and .bin files and extract each supported archive into a sibling _extraido folder." />
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TextBox_UnpackRootPath"
                                     TextChanged="TextBox_UnpackRootPath_TextChanged"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" />
                            <Button x:Name="Button_SelectUnpackRoot"
                                    Click="Button_SelectUnpackRoot_Click"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource ButtonAccent}"
                                    Content="Select Root"
                                    Width="110" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="TOOLS AND OPTIONS" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Tool and Options" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Point to gmad.exe, define existing-output handling, and choose optional post-extraction behavior." />

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                            <StackPanel>
                        <TextBlock Style="{StaticResource LabelText}" Margin="0,0,0,0" Text="gmad.exe" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TextBox_UnpackGmadPath"
                                     TextChanged="TextBox_UnpackGmadPath_TextChanged"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" />
                            <Button x:Name="Button_AutoDetectGmad"
                                    Click="Button_AutoDetectGmad_Click"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Content="Auto-detect"
                                    Width="100" />
                            <Button x:Name="Button_BrowseGmad"
                                    Click="Button_BrowseGmad_Click"
                                    Grid.Column="2"
                                    Margin="8,0,0,0"
                                    Content="Browse"
                                    Width="80" />
                        </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelText}" Text="Existing output" />
                                <ComboBox x:Name="ComboBox_UnpackExistingMode">
                                    <ComboBoxItem Tag="skip" Content="Skip existing" />
                                    <ComboBoxItem Tag="overwrite" Content="Overwrite existing" />
                                    <ComboBoxItem Tag="fail" Content="Fail if exists" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Style="{StaticResource LabelText}" Text="Behavior" />
                                <CheckBox x:Name="CheckBox_UnpackOpenOnFinish"
                                          Margin="0,6,0,0"
                                          Content="Open root folder on finish" />
                                <CheckBox x:Name="CheckBox_UnpackExtractMapPak"
                                          Margin="0,6,0,0"
                                          IsChecked="True"
                                          Content="Extract internal map content (BSP pakfile)"
                                          ToolTip="After normal .gma/.bin extraction, auto-detect maps/*.bsp and extract the internal BSP pakfile into the same _extraido folder." />
                                <CheckBox x:Name="CheckBox_UnpackDeleteMapBsp"
                                          Margin="0,6,0,0"
                                          IsChecked="False"
                                          Content="Delete extracted .bsp after map content extraction"
                                          ToolTip="If the BSP pakfile was extracted successfully, remove the extracted maps/*.bsp file afterward. Disable this if you want to keep the BSP." />
                            </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Style="{StaticResource MutedText}"
                                   Margin="0,12,0,0"
                                   Text="BIN suportado: stream LZMA cujo payload e GMAD. BIN com payload nao-GMAD e listado como unsupported, sem interromper o lote." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="RESULTS" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Summary" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Review the extraction overview first, then inspect the live counters for found, supported, skipped, and failed items." />
                        <TextBox x:Name="TextBox_UnpackSummary"
                                 Margin="0,16,0,0"
                                 Style="{StaticResource ReportTextBox}"
                                 MinHeight="128" />

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="Found" />
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TextBlock_UnpackFoundCount" Style="{StaticResource ValueText}" Text="0" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Margin="16,0,0,0" Style="{StaticResource LabelText}" Text="GMA" />
                            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="TextBlock_UnpackGmaCount" Style="{StaticResource ValueText}" Text="0/0" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}" Text="BIN supported" />
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TextBlock_UnpackBinSupportedCount" Style="{StaticResource ValueText}" Text="0" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Margin="16,0,0,0" Style="{StaticResource LabelText}" Text="BIN unsupported" />
                            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="TextBlock_UnpackBinUnsupportedCount" Style="{StaticResource ValueText}" Text="0" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="OK" />
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TextBlock_UnpackOkCount" Style="{StaticResource ValueText}" Text="0" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Margin="16,0,0,0" Style="{StaticResource LabelText}" Text="Skipped" />
                            <TextBlock Grid.Row="2" Grid.Column="3" x:Name="TextBlock_UnpackSkippedCount" Style="{StaticResource ValueText}" Text="0" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="Failed" />
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TextBlock_UnpackFailedCount" Style="{StaticResource ValueText}" Text="0" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Style="{StaticResource CardEyebrowText}" Text="EXECUTION" />
                            <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Run" />
                            <TextBlock Style="{StaticResource HintText}"
                                       Margin="0,0,0,12"
                                       Text="Scan, extract, cancel, and open the output root from one consistent execution panel." />
                            <Border Style="{StaticResource ActionBarCard}" Margin="0,16,0,0">
                                <WrapPanel>
                                    <Button x:Name="Button_UnpackScan"
                                            Style="{StaticResource ButtonAccent}"
                                            Click="Button_UnpackScan_Click"
                                            Content="Scan"
                                            Width="100"
                                            Margin="0,0,8,8" />
                                    <Button x:Name="Button_UnpackRun"
                                            Style="{StaticResource ButtonAccent}"
                                            Click="Button_UnpackRun_Click"
                                            Content="Extract"
                                            Width="100"
                                            Margin="0,0,8,8"
                                            IsEnabled="False" />
                                    <Button x:Name="Button_UnpackCancel"
                                            Style="{StaticResource ButtonDanger}"
                                            Click="Button_UnpackCancel_Click"
                                            Content="Cancel"
                                            Width="100"
                                            Margin="0,0,8,8"
                                            IsEnabled="False" />
                                    <Button x:Name="Button_UnpackOpenRoot"
                                            Click="Button_UnpackOpenRoot_Click"
                                            Content="Open Root"
                                            Width="100"
                                            Margin="0,0,0,8"
                                            IsEnabled="False" />
                                </WrapPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Progress" />
                                <ProgressBar x:Name="ProgressBar_Unpack"
                                             Margin="0,10,0,0"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="Phase" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Margin="16,0,0,0"
                                           x:Name="TextBlock_UnpackPhase"
                                           Style="{StaticResource StatusTextBlockStyle}"
                                           Text="Idle" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Margin="0,10,0,0"
                                           Style="{StaticResource LabelText}"
                                           Text="Current item" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Margin="16,10,0,0"
                                           x:Name="TextBlock_UnpackCurrent"
                                           Style="{StaticResource ValueText}"
                                           Text="Idle" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelText}" Text="Status" />
                                <TextBlock Grid.Column="1"
                                           Margin="16,0,0,0"
                                           x:Name="TextBlock_UnpackStatus"
                                           Style="{StaticResource ValueText}"
                                           Text="Idle" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Log" />
                                <TextBox x:Name="TextBox_UnpackLog"
                                         Style="{StaticResource LogTextBox}"
                                         Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                </Grid>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Juntar addons">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Grid Background="{DynamicResource AppBackground}" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.25*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="MERGE INPUT" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Root Folder" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Select a root folder that contains multiple addon folders. The merge stays defensive by default and does not overwrite conflicting content blindly." />

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Addon root" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TextBox_AddonMergeRootPath"
                                             TextChanged="TextBox_AddonMergeRootPath_TextChanged"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap" />
                                    <Button x:Name="Button_SelectAddonMergeRoot"
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ButtonAccent}"
                                            Click="Button_SelectAddonMergeRoot_Click"
                                            Content="Select Root"
                                            Width="110" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Safe default" />
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Text="Default behavior keeps the higher-priority addon on real same-path conflicts. Priority order decides the winner and discarded files are still reported." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="POLICY AND PACKAGING" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Options" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Scan first, choose how conflicts should be handled, and optionally generate a .gma only when you actually need workshop packaging." />

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                            <StackPanel>
                                <CheckBox x:Name="CheckBox_AddonMergeGenerateGma"
                                          Content="Generate .gma package at the end"
                                          IsChecked="False"
                                          Checked="CheckBox_AddonMergeGenerateGma_Changed"
                                          Unchecked="CheckBox_AddonMergeGenerateGma_Changed" />
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Text="Disabled by default. When unchecked, the tool only creates the merged addon folder and skips gmad packaging." />

                                <TextBlock Style="{StaticResource LabelText}" Margin="0,12,0,0" Text="gmad.exe" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TextBox_AddonMergeGmadPath"
                                             Text="{Binding ElementName=TextBox_UnpackGmadPath, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="TextBox_AddonMergeGmadPath_TextChanged"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap" />
                                    <Button x:Name="Button_AddonMergeAutoDetectGmad"
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Click="Button_AddonMergeAutoDetectGmad_Click"
                                            Content="Auto-detect"
                                            Width="100" />
                                    <Button x:Name="Button_AddonMergeBrowseGmad"
                                            Grid.Column="2"
                                            Margin="8,0,0,0"
                                            Click="Button_AddonMergeBrowseGmad_Click"
                                            Content="Browse"
                                            Width="80" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Conflict policy" />
                                    <ComboBox x:Name="ComboBox_AddonMergeConflictPolicy" Margin="0,8,0,0">
                                        <ComboBoxItem Tag="first" Content="First wins (default)" />
                                        <ComboBoxItem Tag="last" Content="Last wins" />
                                        <ComboBoxItem Tag="fail" Content="Fail on real conflict" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Priority order" />
                                    <ComboBox x:Name="ComboBox_AddonMergePriorityMode" Margin="0,8,0,0">
                                        <ComboBoxItem Tag="name-asc" Content="Name A-Z" />
                                        <ComboBoxItem Tag="name-desc" Content="Name Z-A" />
                                        <ComboBoxItem Tag="discovery" Content="Scan order" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Package mode" />
                                <ComboBox x:Name="ComboBox_AddonMergePackageMode"
                                          Margin="0,10,0,0"
                                          SelectionChanged="ComboBox_AddonMergePackageMode_SelectionChanged">
                                    <ComboBoxItem Tag="strict" Content="Strict (recommended)" />
                                    <ComboBoxItem Tag="compatibility" Content="Compatibility (explicit discards)" />
                                </ComboBox>
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Text="Compatibility mode currently discards known package-incompatible files such as models/*.sw.vtx and reports them in the final diagnostics." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="SUMMARY" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Scan and Merge Summary" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Review the scan first. Real conflicts, discarded files, and packaging state are surfaced clearly before you trust the final addon." />

                        <TextBox x:Name="TextBox_AddonMergeSummary"
                                 Margin="0,16,0,0"
                                 Style="{StaticResource ReportTextBox}"
                                 MinHeight="150" />

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="Addons" />
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TextBlock_AddonMergeAddonCount" Style="{StaticResource ValueText}" Text="0" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Margin="16,0,0,0" Style="{StaticResource LabelText}" Text="Files" />
                                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="TextBlock_AddonMergeFileCount" Style="{StaticResource ValueText}" Text="0" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="Unique paths" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" x:Name="TextBlock_AddonMergeUniquePathCount" Style="{StaticResource ValueText}" Text="0" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Margin="16,10,0,0" Style="{StaticResource LabelText}" Text="Real conflicts" />
                                <TextBlock Grid.Row="1" Grid.Column="3" Margin="0,10,0,0" x:Name="TextBlock_AddonMergeConflictCount" Style="{StaticResource ValueText}" Text="0" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="Discarded" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" x:Name="TextBlock_AddonMergeDiscardedCount" Style="{StaticResource ValueText}" Text="0" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Margin="16,10,0,0" Style="{StaticResource LabelText}" Text="Merged files" />
                                <TextBlock Grid.Row="2" Grid.Column="3" Margin="0,10,0,0" x:Name="TextBlock_AddonMergeMergedFileCount" Style="{StaticResource ValueText}" Text="0" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource LabelText}" Text="Merge status" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" x:Name="TextBlock_AddonMergeMergeStatus" Style="{StaticResource ValueText}" Text="Idle" />
                                <TextBlock Grid.Row="3" Grid.Column="2" Margin="16,10,0,0" Style="{StaticResource LabelText}" Text="Validation" />
                                <TextBlock Grid.Row="3" Grid.Column="3" Margin="0,10,0,0" x:Name="TextBlock_AddonMergeValidationStatus" Style="{StaticResource ValueText}" Text="Idle" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Style="{StaticResource CardEyebrowText}" Text="EXECUTION" />
                            <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Run" />
                            <TextBlock Style="{StaticResource HintText}"
                                       Margin="0,0,0,12"
                                       Text="Run a safe scan first, then generate the consolidated addon only after reviewing the inventory and conflict policy." />
                            <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource LabelText}" Text="New addon name" />
                                    <TextBox x:Name="TextBox_AddonMergeBundleName"
                                             Margin="0,10,0,0"
                                             TextChanged="TextBox_AddonMergeBundleName_TextChanged"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap" />

                                    <TextBlock Style="{StaticResource LabelText}" Margin="0,12,0,0" Text="Save inside" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TextBox_AddonMergeOutputRoot"
                                                 TextChanged="TextBox_AddonMergeOutputRoot_TextChanged"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 TextWrapping="NoWrap" />
                                        <Button Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Click="Button_SelectAddonMergeOutputRoot_Click"
                                                Content="Browse"
                                                Width="80" />
                                        <Button Grid.Column="2"
                                                Margin="8,0,0,0"
                                                Click="Button_AddonMergeUseRootOutput_Click"
                                                Content="Use root"
                                                Width="90" />
                                    </Grid>
                                    <TextBlock Style="{StaticResource MutedText}"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Text="By default, the merged addon folder and .gma are created inside the selected source root. You can change the destination if needed." />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ActionBarCard}" Margin="0,16,0,0">
                                <StackPanel>
                                    <WrapPanel>
                                        <Button x:Name="Button_AddonMergeScan"
                                                Style="{StaticResource ButtonAccent}"
                                                Click="Button_AddonMergeScan_Click"
                                                Content="Scan"
                                                Width="100"
                                                Margin="0,0,8,8" />
                                        <Button x:Name="Button_AddonMergeRun"
                                                Style="{StaticResource ButtonAccent}"
                                                Click="Button_AddonMergeRun_Click"
                                                Content="Generate"
                                                Width="110"
                                                Margin="0,0,8,8"
                                                IsEnabled="False" />
                                        <Button x:Name="Button_AddonMergeCancel"
                                                Style="{StaticResource ButtonDanger}"
                                                Click="Button_AddonMergeCancel_Click"
                                                Content="Cancel"
                                                Width="100"
                                                Margin="0,0,0,8"
                                                IsEnabled="False" />
                                    </WrapPanel>
                                    <WrapPanel Margin="0,2,0,0">
                                        <Button x:Name="Button_AddonMergeOpenRoot"
                                                Click="Button_AddonMergeOpenRoot_Click"
                                                Content="Open Root"
                                                Width="100"
                                                Margin="0,0,8,8"
                                                IsEnabled="False" />
