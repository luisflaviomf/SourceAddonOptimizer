<Window x:Class="GmodAddonCompressor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GmodAddonCompressor"
        mc:Ignorable="d"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}"
        Title="GMod Addon Optimizer"
        MinHeight="520"
        MinWidth="900"
        Height="720"
        Width="1280">
    <Grid Background="{DynamicResource AppBackground}">
    <TabControl Margin="12"
                Background="{DynamicResource AppBackground}"
                BorderBrush="{DynamicResource Border}">
        <TabItem Header="Compress">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource AppBackground}">
                <Grid Background="{DynamicResource AppBackground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.45*" />
                    </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="COMPRESS INPUT" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Addon" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,10"
                                   Text="Pick the addon root. Compress writes to a separate output folder so the original stays untouched." />
                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource LabelText}" Text="Source addon" />
                            <Button Style="{StaticResource HelpIconButton}"
                                    Content="?"
                                    Margin="8,0,0,0"
                                    ToolTipService.Placement="Mouse"
                                    ToolTipService.InitialShowDelay="250"
                                    ToolTipService.ShowDuration="30000">
                                <Button.ToolTip>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Selecione a pasta do addon que você quer processar." />
                                        <LineBreak />
                                        <Run Text="Recomendado: selecione a pasta raiz do addon (onde ficam folders como materials/, models/, sound/, lua/)." />
                                        <LineBreak />
                                        <Run Text="Efeito: o programa cria um output (nova pasta) com os arquivos processados, preservando o original." />
                                    </TextBlock>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="Button_SelectDirectory"
                                    Style="{StaticResource ButtonAccent}"
                                    Content="Select Addon"
                                    Width="110"
                                    IsEnabled="{Binding UnlockedUI}" />
                            <TextBox x:Name="TextBox_DirectoryPath"
                                     Grid.Column="1"
                                     Margin="12,0,0,0"
                                     IsReadOnly="True"
                                     Text="{Binding AddonDirectoryPath}"
                                     TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>

                        <Border Style="{StaticResource CardInnerPanel}"
                                Margin="0,12,0,0"
                                Visibility="{Binding AddonWorkshopWarningVisibility}"
                                BorderBrush="{DynamicResource Danger}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}"
                                           Foreground="{DynamicResource Danger}"
                                           Text="{Binding AddonWorkshopWarningHeaderText}" />
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,4,0,0"
                                           Text="This addon still references workshop content that should be updated before publishing." />
                                <Expander Margin="0,8,0,0" Header="Show locations">
                                    <TextBox Margin="0,8,0,0"
                                             Text="{Binding AddonWorkshopWarningText}"
                                             Style="{StaticResource ReportTextBox}"
                                             Foreground="{DynamicResource Danger}"
                                             BorderBrush="{DynamicResource Danger}"
                                             MinHeight="72" />
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ActionBarCard}" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Button x:Name="Button_Compress"
                                            Style="{StaticResource ButtonAccent}"
                                            Content="Compress"
                                            Width="140"
                                            Height="40"
                                            IsEnabled="{Binding UnlockedUI}" />
                                    <TextBlock Style="{StaticResource MutedText}"
                                               Margin="0,6,0,0"
                                               Text="Runs on the enabled asset types with the settings from this tab." />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="18,0,0,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right">
                                    <TextBlock Style="{StaticResource MutedText}" Text="Optional diagnostics" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <CheckBox x:Name="CheckBox_DebugConsole"
                                                  Content="Debug Console"
                                                  Checked="CheckBox_EnableDebugConsole"
                                                  Unchecked="CheckBox_DisableDebugConsole" />
                                        <Button Style="{StaticResource HelpIconButton}"
                                                Content="?"
                                                Margin="8,0,0,0"
                                                ToolTipService.Placement="Mouse"
                                                ToolTipService.InitialShowDelay="250"
                                                ToolTipService.ShowDuration="35000">
                                            <Button.ToolTip>
                                                <TextBlock TextWrapping="Wrap">
                                                    <Run Text="Abre um console para ver logs/saÃ­das de debug enquanto o programa roda." />
                                                    <LineBreak />
                                                    <Run Text="Recomendado: habilite apenas se precisar reportar bug ou acompanhar detalhes de processamento." />
                                                    <LineBreak />
                                                    <Run Text="Dica: se fechar o console, o app continua aberto (o console serve sÃ³ para diagnÃ³stico)." />
                                                </TextBlock>
                                            </Button.ToolTip>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Live status" />
                                <ProgressBar x:Name="ProgressBar_Compress"
                                             Margin="0,8,0,0"
                                             Minimum="{Binding ProgressBarMinValue}"
                                             Maximum="{Binding ProgressBarMaxValue}"
                                             Value="{Binding ProgressBarValue}" />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource LabelText}"
                                               Text="Status" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusTextBlockStyle}">
                                                <Setter Property="Text" Value="Ready" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UnlockedUI}" Value="False">
                                                        <Setter Property="Text" Value="Working" />
                                                        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <TextBlock Margin="0,8,0,0" Text="Waiting to start.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProgressBarText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ProgressBarText}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding UnlockedUI}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Grid Margin="0,8,0,0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProgressBarText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ProgressBarText}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource LabelText}"
                                               Text="Current item" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               Style="{StaticResource ValueText}"
                                               Text="{Binding ProgressBarText}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,10,0,0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource CardInnerPanel}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CompressSizeReportText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CompressSizeReportText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Size report" />
                                <TextBox Text="{Binding CompressSizeReportText}"
                                         Style="{StaticResource ReportTextBox}"
                                         Margin="0,8,0,0"
                                         MinHeight="96" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,14,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="ASSET TYPES" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Types" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,10"
                                   Text="Choose which file groups can be processed. Disabled types stay untouched." />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource LabelText}" Text="Processing types" />
                            <Button Style="{StaticResource HelpIconButton}"
                                    Content="?"
                                    Margin="8,0,0,0"
                                    ToolTipService.Placement="Mouse"
                                    ToolTipService.InitialShowDelay="250"
                                    ToolTipService.ShowDuration="35000">
                                <Button.ToolTip>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Escolha quais tipos de arquivo serão processados na compressão." />
                                        <LineBreak />
                                        <Run Text="Recomendado: marque apenas o que existe no seu addon e o que você realmente quer reduzir." />
                                        <LineBreak />
                                        <Run Text="Efeito: itens desmarcados ficam intocados (copiados/ignorados conforme o pipeline), e itens marcados podem ganhar tamanho menor com possível perda de qualidade (principalmente imagens e áudio)." />
                                    </TextBlock>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>
                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <UniformGrid Columns="2">
                            <CheckBox Margin="0,0,0,8" Content="WAV" IsChecked="{Binding CompressWAV}" />
                            <CheckBox Margin="0,0,0,8" Content="MP3" IsChecked="{Binding CompressMP3}" />
                            <CheckBox Margin="0,0,0,8" Content="OGG" IsChecked="{Binding CompressOGG}" />
                            <CheckBox Margin="0,0,0,8" Content="VTF" IsChecked="{Binding CompressVTF}" />
                            <CheckBox Margin="0,0,0,8" Content="JPG" IsChecked="{Binding CompressJPG}" />
                            <CheckBox Margin="0,0,0,8" Content="PNG" IsChecked="{Binding CompressPNG}" />
                            <CheckBox Margin="0,0,0,8" Content="LUA" IsChecked="{Binding CompressLUA}" />
                            </UniformGrid>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,10,0,0">
                            <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource LabelText}" Text="Audio profiles" />
                                <Button Style="{StaticResource HelpIconButton}"
                                        Content="?"
                                        Margin="8,0,0,0"
                                        ToolTipService.Placement="Mouse"
                                        ToolTipService.InitialShowDelay="250"
                                        ToolTipService.ShowDuration="60000">
                                    <Button.ToolTip>
                                        <TextBlock TextWrapping="Wrap">
                                            <Run Text="Configura o ?udio por tipo (WAV/MP3/OGG), sem converter formatos." />
                                            <LineBreak />
                                            <Run Text="WAV: recomendado para sons de loop perfeito (engine/ambient/idle)." />
                                            <LineBreak />
                                            <Run Text="MP3: melhor para sons n?o-loopados (m?sicas e efeitos longos)." />
                                            <LineBreak />
                                            <Run Text="OGG: compressao eficiente e melhor para loop do que MP3." />
                                            <LineBreak />
                                            <Run Text="OGG usa VBR; a qualidade (q2-q5) e um alvo e o bitrate varia." />
                                            <LineBreak />
                                            <Run Text="Looped WAV: preservado automaticamente para manter loop points." />
                                            <LineBreak />
                                            <Run Text="FFmpeg ? necess?rio para o processamento de ?udio." />
                                        </TextBlock>
                                    </Button.ToolTip>
                                </Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0"
                                       Text="Only enabled audio types show settings. Formats stay the same." />

                            <TextBlock Style="{StaticResource MutedText}"
                                       Margin="0,10,0,0"
                                       Visibility="{Binding CompressNoAudioProfileVisibility}"
                                       Text="Enable WAV, MP3 or OGG above to reveal per-format settings." />

                            <StackPanel Visibility="{Binding CompressAnyAudioProfileVisibility}">
                                <StackPanel Margin="0,10,0,0"
                                            IsEnabled="{Binding CompressWAV}"
                                            Visibility="{Binding CompressWavProfileVisibility}">
                                    <TextBlock Style="{StaticResource LabelText}" Text="WAV" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Sample rate" />
                                            <ComboBox ItemsSource="{Binding WavRateList, Mode=OneTime}"
                                                      SelectedIndex="{Binding WavRateListIndex, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Channels" />
                                            <ComboBox ItemsSource="{Binding WavChannelList, Mode=OneTime}"
                                                      SelectedIndex="{Binding WavChannelsIndex, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Codec WAV" />
                                            <ComboBox ItemsSource="{Binding WavCodecList, Mode=OneTime}"
                                                      SelectedIndex="{Binding WavCodecIndex, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Grid>
                                    <CheckBox Margin="0,8,0,0"
                                              Content="Protect WAV loop behavior when possible"
                                              IsChecked="{Binding AudioLoopSafe}" />
                                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0"
                                               Text="Recommended starting point: 22050 Hz, mono, ADPCM." />
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0"
                                            IsEnabled="{Binding CompressMP3}"
                                            Visibility="{Binding CompressMp3ProfileVisibility}">
                                    <TextBlock Style="{StaticResource LabelText}" Text="MP3" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Sample rate" />
                                            <ComboBox ItemsSource="{Binding WavRateList, Mode=OneTime}"
                                                      SelectedIndex="{Binding Mp3RateIndex, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Bitrate (CBR)" />
                                            <ComboBox ItemsSource="{Binding AudioBitrateList, Mode=OneTime}"
                                                      SelectedIndex="{Binding Mp3BitrateIndex, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0"
                                               Text="Avoid MP3 for seamless loops." />
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0"
                                            IsEnabled="{Binding CompressOGG}"
                                            Visibility="{Binding CompressOggProfileVisibility}">
                                    <TextBlock Style="{StaticResource LabelText}" Text="OGG" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Sample rate" />
                                            <ComboBox ItemsSource="{Binding WavRateList, Mode=OneTime}"
                                                      SelectedIndex="{Binding OggRateIndex, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Quality (Vorbis)" />
                                            <ComboBox ItemsSource="{Binding OggQualityList, Mode=OneTime}"
                                                      SelectedIndex="{Binding OggQualityIndex, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Channels" />
                                            <ComboBox ItemsSource="{Binding WavChannelList, Mode=OneTime}"
                                                      SelectedIndex="{Binding OggChannelsIndex, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0"
                                               Text="VBR target; 22050 Hz mono q3 is the default starting point." />
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardEyebrowText}" Text="SETTINGS" />
                        <TextBlock Style="{StaticResource CardHeaderTitle}" Text="Options" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="Shared image limits stay explicit while Standard and Magick remain clearly separated and optional." />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource LabelText}" Text="Image and routing rules" />
                            <Button Style="{StaticResource HelpIconButton}"
                                    Content="?"
                                    Margin="8,0,0,0"
                                    ToolTipService.Placement="Mouse"
                                    ToolTipService.InitialShowDelay="250"
                                    ToolTipService.ShowDuration="45000">
                                <Button.ToolTip>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Configura limites e regras de redução (principalmente imagens/texturas)." />
                                        <LineBreak />
                                        <Run Text="Width/Height limit = “piso” de resolução: ele NÃO deixa a imagem ficar menor do que esse valor." />
                                        <LineBreak />
                                        <Run Text="Ex.: Limit 1024 + redução 4x em uma imagem 2048 → vai para 1024 (não 512)." />
                                        <LineBreak />
                                        <Run Text="Se a imagem já for menor que o limit, ela não é reduzida." />
                                    </TextBlock>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Compression mode" />
                                <ComboBox ItemsSource="{Binding CompressModeList, Mode=OneTime}"
                                          Margin="0,10,0,0"
                                          SelectedIndex="{Binding CompressModeIndex, Mode=TwoWay}" />

                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0"
                                           Text="{Binding CompressModeDescriptionText}"
                                           TextWrapping="Wrap" />

                                <TextBlock Style="{StaticResource LabelText}" Margin="0,12,0,0" Text="Routing" />
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,6,0,0"
                                           Text="{Binding CompressModeRoutingText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0">
                            <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource LabelText}" Text="Reducing resolution" />
                            <Button Style="{StaticResource HelpIconButton}"
                                    Content="?"
                                    Margin="8,0,0,0"
                                    ToolTipService.Placement="Mouse"
                                    ToolTipService.InitialShowDelay="250"
                                    ToolTipService.ShowDuration="35000">
                                <Button.ToolTip>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Controla o fator de redução aplicado às imagens antes da compressão." />
                                        <LineBreak />
                                        <Run Text="O resultado final é limitado por Width/Height limit (não reduz abaixo do limit)." />
                                        <LineBreak />
                                        <Run Text="Recomendado: comece suave e aumente só se o ganho de tamanho valer a perda de qualidade." />
                                    </TextBlock>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>
                        <TextBlock Style="{StaticResource MutedText}"
                                   Margin="0,6,0,0"
                                   Text="These shared image settings stay the same in both Standard and Magick modes; only eligible files change route."
                                   TextWrapping="Wrap" />
                        <ComboBox ItemsSource="{Binding ImageReducingResolutionList, Mode=OneTime}"
                                  Margin="0,10,0,0"
                                  SelectedIndex="{Binding ImageReducingResolutionListIndex, Mode=TwoWay}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelText}" Text="Width limit" />
                                <ComboBox ItemsSource="{Binding ImageSizeLimitList, Mode=OneTime}"
                                          SelectedIndex="{Binding ImageWidthLimitIndex, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Style="{StaticResource LabelText}" Text="Height limit" />
                                <ComboBox ItemsSource="{Binding ImageSizeLimitList, Mode=OneTime}"
                                          SelectedIndex="{Binding ImageHeightLimitIndex, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelText}" Text="Skip width" />
                                <TextBox Text="{Binding ImageSkipWidth}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Style="{StaticResource LabelText}" Text="Skip height" />
                                <TextBox Text="{Binding ImageSkipHeight}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,12,0,0">
                            <CheckBox Content="Reduce exactly to limits" IsChecked="{Binding ReduceExactlyToLimits}" />
                            <CheckBox Margin="0,8,0,0" Content="Maintain image aspect ratio" IsChecked="{Binding KeepImageAspectRatio}" />
                        </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0" Visibility="{Binding CompressStandardOptionsVisibility}">
                            <StackPanel>
                            <TextBlock Style="{StaticResource LabelText}" Text="Standard mode extras" />
                            <CheckBox Margin="0,8,0,0"
                                      IsChecked="{Binding ImageMagickVTFCompress}">
                                <TextBlock Text="Legacy ImageMagick VTF demo inside Standard mode"
                                           TextWrapping="Wrap" />
                            </CheckBox>
                            <TextBlock Style="{StaticResource MutedText}"
                                       Margin="0,6,0,0"
                                       Text="This keeps the old demo toggle available without changing the new Magick mode."
                                       TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardInnerPanel}" Margin="0,12,0,0" Visibility="{Binding CompressMagickOptionsVisibility}">
                            <StackPanel>
                            <TextBlock Style="{StaticResource LabelText}" Text="Magick mode extras" />
                            <CheckBox Margin="0,8,0,0"
                                      IsChecked="{Binding CompressMagickUseCommonVtf}"
                                      IsEnabled="{Binding CompressVTF}">
                                <TextBlock Text="Use Magick for common VTF textures (recommended)"
                                           TextWrapping="Wrap" />
